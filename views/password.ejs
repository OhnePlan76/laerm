<%- include("partials/header", { title }) %>

<section class="auth-shell">
  <form class="auth-panel" method="post" action="/password/change" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <h1><%= mustChangePassword ? "Passwort festlegen" : "Passwort ändern" %></h1>

    <% if (mustChangePassword) { %>
      <p class="muted">Bitte lege ein eigenes Passwort fest. Danach wird das Startpasswort nicht mehr verwendet.</p>
    <% } %>

    <% if (!mustChangePassword) { %>
      <label>
        Aktuelles Passwort
        <input type="password" name="current_password" autocomplete="current-password" required autofocus>
        <% if (errors.current_password) { %><span class="error"><%= errors.current_password %></span><% } %>
      </label>
    <% } %>

    <label>
      Neues Passwort
      <input type="password" name="password" autocomplete="new-password" required <%= mustChangePassword ? "autofocus" : "" %>>
      <% if (errors.password) { %><span class="error"><%= errors.password %></span><% } %>
    </label>

    <label>
      Neues Passwort wiederholen
      <input type="password" name="password_confirmation" autocomplete="new-password" required>
      <% if (errors.password_confirmation) { %><span class="error"><%= errors.password_confirmation %></span><% } %>
    </label>

    <button class="button button-primary" type="submit">Passwort speichern</button>
    <% if (!mustChangePassword) { %>
      <a class="button" href="/">Abbrechen</a>
    <% } %>
  </form>
</section>

<%- include("partials/footer") %>
